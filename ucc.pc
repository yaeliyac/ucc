prefix = /mtrsysgwork/yyacobovich/install/install_gaia
exec_prefix = ${prefix}
bindir = ${prefix}/bin
libdir = ${exec_prefix}/lib
includedir = ${prefix}/include

Name: ucc
Description: Unified Collective Communication Library
Version: 1.7.0
Cflags: -I${includedir}
Libs: -L${libdir} -lucc
Libs.private: -Wl
